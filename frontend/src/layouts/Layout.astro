---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | CrateKeeper</title>
  </head>
  <body class="bg-cream text-espresso min-h-screen flex flex-col">
    <nav class="bg-espresso px-6 py-4 flex items-center justify-between">
      <div>
        <a href="/" class="flex items-center gap-3 group">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="11" stroke="#FAC775" stroke-width="1"/>
            <circle cx="12" cy="12" r="8.5" stroke="#FAC775" stroke-width="0.6" opacity="0.5"/>
            <circle cx="12" cy="12" r="6" stroke="#FAC775" stroke-width="0.6" opacity="0.4"/>
            <circle cx="12" cy="12" r="3.5" stroke="#FAC775" stroke-width="0.6" opacity="0.35"/>
            <circle cx="12" cy="12" r="1.2" fill="#FAC775"/>
          </svg>
          <div>
            <div class="font-serif text-gold text-xl leading-none tracking-wide">CrateKeeper</div>
            <div class="text-gold-mid text-[9px] tracking-[0.18em] uppercase mt-0.5 opacity-75">Est. Your Collection</div>
          </div>
        </a>
      </div>
      <div class="flex gap-6 items-center">
        <a href="/collection" class="text-gold text-xs tracking-[0.1em] uppercase opacity-70 hover:opacity-100 transition-opacity">Collection</a>
        <a href="/wishlist" class="text-gold text-xs tracking-[0.1em] uppercase opacity-70 hover:opacity-100 transition-opacity">Wishlist</a>
        <a href="/login" class="text-xs tracking-[0.08em] uppercase bg-gold text-espresso font-medium px-4 py-1.5 rounded hover:bg-gold-mid transition-colors">Sign in</a>
      </div>
    </nav>
    <main class="flex-1 px-6 py-8 max-w-5xl mx-auto w-full">
      <slot />
    </main>
    <footer class="bg-espresso px-6 py-4 flex items-center justify-between">
      <span class="text-gold text-[10px] tracking-[0.1em] uppercase opacity-50">CrateKeeper · Private Collection</span>
      <span class="text-[10px] text-gold-mid opacity-50 tracking-wide">Built for serious diggers</span>
    </footer>
  </body>
</html>
