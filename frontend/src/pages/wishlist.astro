---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Wishlist">
  <div class="space-y-8">

    <div class="flex items-end justify-between border-b border-gold-muted/30 pb-6">
      <div>
        <h1 class="font-serif text-4xl text-espresso font-normal mb-1">Wishlist</h1>
        <p class="text-gold-dark text-xs tracking-[0.12em] uppercase">Records you're hunting for</p>
      </div>
      <button class="bg-espresso text-gold text-xs tracking-[0.1em] uppercase px-4 py-2 rounded">+ Add to Wishlist</button>
    </div>

    <div class="space-y-2">
      {[
        { title: 'In the Wee Small Hours', artist: 'Frank Sinatra', priority: 'High', target: '$80', notes: 'OG Capitol pressing only' },
        { title: 'Sketches of Spain', artist: 'Miles Davis', priority: 'Medium', target: '$45', notes: 'Any pressing, good condition' },
        { title: 'Getz / Gilberto', artist: 'Stan Getz & João Gilberto', priority: 'High', target: '$120', notes: 'US Verve original' },
      ].map(({ title, artist, priority, target, notes }) => (
        <div class="bg-white border border-gold/50 rounded-lg px-5 py-4 flex items-center gap-5 hover:border-gold transition-colors">
          <div class="w-10 h-10 flex-shrink-0">
            <svg width="40" height="40" viewBox="0 0 40 40" aria-hidden="true">
              <circle cx="20" cy="20" r="19" fill="#1a1a18" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
              <circle cx="20" cy="20" r="15" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.7"/>
              <circle cx="20" cy="20" r="11" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.7"/>
              <circle cx="20" cy="20" r="7" fill="#854F0B"/>
              <circle cx="20" cy="20" r="1.5" fill="rgba(0,0,0,0.5)"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-serif text-sm text-espresso">{title}</div>
            <div class="text-[11px] text-gold-dark mt-0.5">{artist}</div>
            {notes && <div class="text-[10px] text-gold-muted mt-1 italic">{notes}</div>}
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-xs font-medium text-espresso">{target}</div>
            <div class={`text-[9px] tracking-[0.1em] uppercase mt-1 ${priority === 'High' ? 'text-gold-dark' : 'text-gold-muted'}`}>{priority} priority</div>
          </div>
        </div>
      ))}
    </div>

    <div class="bg-espresso/5 border border-gold-muted/20 rounded-lg p-8 text-center">
      <div class="font-serif text-espresso text-lg mb-1">Still hunting?</div>
      <p class="text-gold-dark text-xs tracking-wide mb-4">Add records you're looking for and track your target price.</p>
      <button class="bg-espresso text-gold text-xs tracking-[0.1em] uppercase px-5 py-2.5 rounded">+ Add a Record to Hunt</button>
    </div>

  </div>
</Layout>
