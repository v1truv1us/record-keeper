---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dashboard">
  <div class="space-y-10">

    <div class="border-b border-gold-muted/30 pb-6">
      <h1 class="font-serif text-4xl text-espresso mb-1 font-normal">Your Crates</h1>
      <p class="text-gold-dark text-xs tracking-[0.12em] uppercase">147 pressings · 23 on the wishlist · 8 for sale</p>
    </div>

    <div class="grid grid-cols-3 gap-4">
      {[
        { num: '147', label: 'In the collection' },
        { num: '$4,820', label: 'Estimated value' },
        { num: '23', label: 'On the wishlist' },
      ].map(({ num, label }) => (
        <div class="bg-espresso rounded-lg p-5">
          <div class="font-serif text-4xl text-gold leading-none mb-2">{num}</div>
          <div class="text-gold-mid text-[10px] tracking-[0.12em] uppercase">{label}</div>
        </div>
      ))}
    </div>

    <div>
      <div class="flex items-center gap-3 mb-5">
        <span class="text-gold-dark text-[10px] tracking-[0.14em] uppercase">Recent additions</span>
        <div class="flex-1 h-px bg-gold-muted opacity-30"></div>
      </div>

      <div class="grid grid-cols-3 gap-4">
        {[
          { title: 'Kind of Blue', artist: 'Miles Davis', year: '1959', pressing: 'Original', grade: 'VG+', labelColor: '#BA7517', labelText: 'Blue Note', discBg: '#2C2C2A' },
          { title: 'A Love Supreme', artist: 'John Coltrane', year: '1965', pressing: 'Repress', grade: 'M', labelColor: '#534AB7', labelText: 'Impulse!', discBg: '#1e1d3a' },
          { title: 'Exodus', artist: 'Bob Marley', year: '1977', pressing: 'UK 1st', grade: 'VG', labelColor: '#0F6E56', labelText: 'Island', discBg: '#0d2b24' },
        ].map(({ title, artist, year, pressing, grade, labelColor, labelText, discBg }) => (
          <div class="bg-white border border-gold/60 rounded-lg overflow-hidden">
            <div class="h-28 flex items-center justify-center" style={`background: ${discBg};`}>
              <svg width="88" height="88" viewBox="0 0 88 88" aria-hidden="true">
                <circle cx="44" cy="44" r="43" fill="#111" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
                <circle cx="44" cy="44" r="37" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.8"/>
                <circle cx="44" cy="44" r="31" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.8"/>
                <circle cx="44" cy="44" r="25" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.8"/>
                <circle cx="44" cy="44" r="19" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="0.8"/>
                <circle cx="44" cy="44" r="14" fill={labelColor}/>
                <text x="44" y="41" text-anchor="middle" font-size="5" fill="rgba(255,255,255,0.9)" font-family="Georgia,serif">{labelText.split(' ')[0]}</text>
                {labelText.split(' ')[1] && <text x="44" y="48" text-anchor="middle" font-size="5" fill="rgba(255,255,255,0.9)" font-family="Georgia,serif">{labelText.split(' ')[1]}</text>}
                <circle cx="44" cy="44" r="2" fill="rgba(0,0,0,0.5)"/>
              </svg>
            </div>
            <div class="p-3.5 border-t border-gold/40">
              <div class="font-serif text-sm text-espresso truncate mb-0.5">{title}</div>
              <div class="text-[11px] text-gold-dark mb-2.5">{artist}</div>
              <div class="flex items-center justify-between">
                <span class="text-[10px] bg-espresso text-gold px-2 py-0.5 rounded tracking-wide">{grade}</span>
                <span class="text-[10px] text-gold-muted">{year} · {pressing}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="flex items-center justify-between pt-2">
      <a href="/collection" class="font-serif italic text-sm text-gold-dark hover:text-espresso transition-colors">Browse all 147 records →</a>
      <button class="bg-espresso text-gold text-xs tracking-[0.1em] uppercase px-5 py-2.5 rounded hover:bg-espresso/90 transition-colors">+ Add a Record</button>
    </div>

  </div>
</Layout>
