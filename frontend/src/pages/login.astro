---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Sign In">
  <div class="max-w-sm mx-auto mt-12">

    <div class="text-center mb-8">
      <svg width="52" height="52" viewBox="0 0 52 52" class="mx-auto mb-4" aria-hidden="true">
        <circle cx="26" cy="26" r="25" fill="#412402"/>
        <circle cx="26" cy="26" r="20" fill="none" stroke="#FAC775" stroke-width="0.8" opacity="0.5"/>
        <circle cx="26" cy="26" r="15" fill="none" stroke="#FAC775" stroke-width="0.8" opacity="0.4"/>
        <circle cx="26" cy="26" r="10" fill="none" stroke="#FAC775" stroke-width="0.8" opacity="0.35"/>
        <circle cx="26" cy="26" r="6" fill="#BA7517"/>
        <circle cx="26" cy="26" r="2" fill="rgba(0,0,0,0.4)"/>
      </svg>
      <h1 class="font-serif text-3xl text-espresso font-normal mb-1">Welcome back</h1>
      <p class="text-gold-dark text-xs tracking-[0.1em] uppercase">Sign in to your collection</p>
    </div>

    <div class="bg-white border border-gold/50 rounded-lg p-6 space-y-4">
      <button class="w-full bg-espresso text-gold text-xs tracking-[0.1em] uppercase py-3 rounded hover:bg-espresso/90 transition-colors">
        Sign in with Passkey
      </button>

      <div class="relative">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gold-muted/30"></div></div>
        <div class="relative text-center">
          <span class="bg-white px-3 text-[10px] text-gold-muted tracking-widest uppercase">or</span>
        </div>
      </div>

      <div class="space-y-2.5">
        <input type="email" placeholder="Email address" class="w-full border border-gold/40 bg-cream text-espresso rounded px-4 py-2.5 text-sm placeholder:text-gold-muted/60 focus:outline-none focus:border-gold-dark" />
        <input type="password" placeholder="Password" class="w-full border border-gold/40 bg-cream text-espresso rounded px-4 py-2.5 text-sm placeholder:text-gold-muted/60 focus:outline-none focus:border-gold-dark" />
        <button class="w-full border border-espresso/30 text-espresso text-xs tracking-[0.08em] uppercase py-2.5 rounded hover:bg-espresso hover:text-gold transition-colors">
          Sign in with email
        </button>
      </div>

      <p class="text-center text-[10px] text-gold-muted tracking-wide">
        New here? <a href="#" class="text-espresso underline underline-offset-2">Create an account</a>
      </p>
    </div>

  </div>
</Layout>
